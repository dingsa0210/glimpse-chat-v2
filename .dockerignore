# 版本控制与元数据
.git
.gitignore
.codebuddy

# 依赖与构建产物（容器内重新安装/构建）
**/node_modules
**/dist
**/.next

# 环境变量文件（避免泄漏，仅保留 .env.example 供参考）
**/.env
**/.env.*
!**/.env.example

# IDE 与系统文件
.vscode
.idea
**/*.log
**/.DS_Store

# 文档与脚本（无需进镜像）
*.md
docs/
*.ps1

# Docker 自身（避免循环复制）
Dockerfile
.dockerignore
docker-compose*.yml

# 生成资源
generated-images

# Prisma 产物（容器内重新 generate）
**/prisma/migrations/**/migration.sql.bak
