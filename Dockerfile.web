# ==================== 构建阶段 ====================
FROM node:24-alpine AS builder

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /build

# 复制 workspace 配置与锁文件
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json tsconfig.base.json ./

# 复制所有包的 package.json
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/

# 安装全部依赖（构建需要）
RUN pnpm install --frozen-lockfile

# 复制源码
COPY apps/web/tsconfig.json apps/web/next.config.ts apps/web/postcss.config.js apps/web/tailwind.config.ts apps/web/
COPY apps/web/public/ apps/web/public/
COPY apps/web/src/ apps/web/src/
COPY packages/shared/tsconfig.json packages/shared/
COPY packages/shared/src/ packages/shared/src/

# 构建 shared 包
RUN pnpm --filter @glimpse/shared build

# 构建 Next.js（standalone 模式）
RUN pnpm --filter @glimpse/web build

# ==================== 生产阶段 ====================
FROM node:24-alpine AS runner

RUN apk add --no-cache tini

WORKDIR /app

ENV NODE_ENV=production

# Next.js standalone 输出自带最小 node_modules，只需复制 standalone 目录 + static + public
COPY --from=builder /build/apps/web/.next/standalone ./
COPY --from=builder /build/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /build/apps/web/public ./apps/web/public

EXPOSE 3000

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "apps/web/server.js"]
