{
  "name": "glimpse-chat-desktop",
  "version": "1.0.0",
  "description": "Glimpse Chat desktop client for Windows",
  "main": "main.cjs",
  "private": true,
  "author": "Glimpse Chat",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "prepare-runtime": "install-electron",
    "dist": "npm run prepare-runtime && electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.glimpsechat.desktop",
    "productName": "Glimpse Chat",
    "artifactName": "Glimpse-Chat-Setup-${version}.${ext}",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "files": [
      "main.cjs",
      "package.json"
    ],
    "directories": {
      "output": "../../release-artifacts/windows-1.0.0"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../../apps/web/public/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Glimpse Chat",
      "deleteAppDataOnUninstall": false
    }
  },
  "allowScripts": {
    "electron@43.1.1": true
  }
}
