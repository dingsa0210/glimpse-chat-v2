# ====================================================================
# Glimpse Chat - 环境变量配置模板
#
# 用法：
#   cp .env.example .env
#   然后按需填写实际值
#
# 规则：
#   - docker compose 会自动读取项目根 .env
#   - api 服务通过 env_file 加载本文件全部变量，无需在 compose 里逐个声明
#   - .env 不进 git（建议在 .gitignore 加 .env），本模板可提交
#   - 留空或保持注释的变量将使用代码默认值
#   - 标记说明：
#       [必改]  必须填写真实值
#       [核对]  因端口可能被改动，需与实际访问地址一致
#       [可选]  按需填写，不配则对应功能降级或不可用
# ====================================================================

# ---------- [必改] JWT 密钥 ----------
# 当前 compose 用的是开发占位值，生产前务必改为长随机串
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ---------- [核对] 前后端访问地址 ----------
# WEB_ORIGIN: api 允许的前端来源（CORS），等于浏览器访问 web 的完整地址（含端口），多个用逗号分隔
WEB_ORIGIN=http://localhost:3001,http://127.0.0.1:3001
# PUBLIC_WEB_URL: 邮件验证 / 密码重置等链接里的 web 地址（含端口）
PUBLIC_WEB_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL / NEXT_PUBLIC_SOCKET_URL: 浏览器访问 api 的地址（含端口）
# 注意：前端构建时注入，改值后必须重新构建 web 镜像 —— docker compose build web
NEXT_PUBLIC_API_URL=http://localhost:4101
NEXT_PUBLIC_SOCKET_URL=http://localhost:4101

# ---------- [可选] 管理员邮箱 ----------
# 逗号分隔，匹配的用户登录时自动获得 ADMIN 角色，用于登录 /admin 后台
ADMIN_EMAILS=

# ---------- 数据库 / Redis（compose 已配默认值，一般不用改） ----------
# DB_NAME=glimpse_chat_v2
# DATABASE_URL=postgresql://glimpse:glimpse_secret_change_me@host.docker.internal:5432/glimpse_chat_v2
# ADMIN_DATABASE_URL=postgresql://glimpse:glimpse_secret_change_me@host.docker.internal:5432/postgres
# REDIS_URL=redis://host.docker.internal:6379/3

# ---------- 种子数据导入控制 ----------
# true = 跳过 database-sanitized.sql 导入，使用空库 + prisma migrate 全新建表
# SEED_SKIP=false

# ---------- [可选] 邮件 SMTP（不配则邮件验证 / 密码重置不可用） ----------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------- [可选] 翻译服务（不配则用 mock；也可启动后在 /admin 后台配） ----------
# 百度翻译
BAIDU_TRANSLATE_APP_ID=
BAIDU_TRANSLATE_API_KEY=
BAIDU_TRANSLATE_SECRET_KEY=
BAIDU_TRANSLATE_SECRET=
# 阿里通义翻译（DashScope）
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_TRANSLATE_MODEL=qwen3.7-plus

# ---------- [可选] 语音 ASR / TTS（不配则用 browser 本地合成） ----------
VOICE_TRANSCRIBE_PROVIDER=doubao
# 豆包
DOUBAO_ASR_API_KEY=
DOUBAO_ASR_MODEL=volc.seedasr.auc
DOUBAO_ASR_BASE_URL=
DOUBAO_ASR_QUERY_URL=
DOUBAO_TTS_API_KEY=
DOUBAO_TTS_MODEL=seed-tts-2.0
DOUBAO_TTS_BASE_URL=
DOUBAO_TTS_VOICE=
DOUBAO_TTS_VOICES_JSON=
# 阿里
ALIYUN_ASR_API_KEY=
ALIYUN_ASR_MODEL=qwen3-asr-flash
ALIYUN_ASR_BASE_URL=
ALIYUN_TTS_API_KEY=
ALIYUN_TTS_MODEL=qwen3.5-omni-plus
ALIYUN_TTS_BASE_URL=
ALIYUN_TTS_VOICE=Tina
# TTS 提供方与缓存
TTS_PROVIDER=browser
TTS_CACHE_DIR=
TTS_CACHE_TTL_SECONDS=86400

# ---------- [可选] OCR / AI 助手（复用 ALIYUN_DASHSCOPE_API_KEY） ----------
ALIYUN_OCR_MODEL=qwen3.7-plus
ALIYUN_ASSISTANT_MODEL=qwen3.7-plus

# ---------- [可选] 媒体处理工具路径（容器内一般未安装，留空即降级） ----------
LIBREOFFICE_PATH=
ODA_FILE_CONVERTER_PATH=
CAXA_CAD_PATH=
CAXA_CRX_PLUGIN_PATH=
PYTHON_PATH=
MEDIA_STORAGE_DIR=
MEDIA_UPLOAD_BODY_LIMIT=750mb

# ---------- [可选] 调优项（有默认值，一般不用改） ----------
JWT_ACCESS_TTL=7d
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000
TRANSLATION_CACHE_TTL_SECONDS=86400
TRANSLATION_CACHE_MAX_ENTRIES=500
TRANSLATION_MAX_REQUESTS_PER_MINUTE=120
API_ERROR_LOG_DIR=

# ---------- MinIO（compose 已配默认值，一般不用改） ----------
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_BUCKET=glimpse-chat
# S3_ACCESS_KEY=glimpse
# S3_SECRET_KEY=glimpse_dev_password

# ---------- 行为开关（compose 已配默认值，一般不用改） ----------
# NODE_ENV=production
# PORT=4100
# CHAT_STORAGE=memory
# DATABASE_CONNECT_ON_START=false
# TRANSLATION_PROVIDER=mock
# ENABLE_SWAGGER=true
