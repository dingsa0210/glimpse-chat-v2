# ==================== 数据库 (PostgreSQL) ====================
DATABASE_URL=postgresql://glimpse:glimpse_secret_change_me@db:5432/glimpse_chat

# ==================== JWT 认证 ====================
JWT_ACCESS_SECRET=chan****************************************************n
JWT_ACCESS_TTL=7d

# ==================== 管理员 ====================
# 逗号分隔的管理员邮箱，注册时自动获得管理员角色
ADMIN_EMAILS=admin@example.com

# ==================== 服务端口 ====================
PORT=4100

# ==================== CORS / 前端地址 ====================
# 生产环境必须设置为具体的前端域名（逗号分隔多个）
WEB_ORIGIN=https://glimpsechat.com

# ==================== 媒体上传 ====================
MEDIA_UPLOAD_BODY_LIMIT=750mb
MEDIA_STORAGE_DIR=/app/uploads

# ==================== API 限流 ====================
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000

# ==================== Redis (可选) ====================
REDIS_URL=redis://redis:6379

# ==================== 运行环境 ====================
NODE_ENV=production

# ==================== 邮件发送 (SMTP) ====================
# 用于发送邮箱验证码的 SMTP 配置
# 腾讯企业邮箱：smtp.exmail.qq.com:465 (SSL)
# Gmail：smtp.gmail.com:587 (STARTTLS)
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@verify.glimpsetech.cn
SMTP_PASS=your_smtp_password_here
SMTP_FROM=noreply@verify.glimpsetech.cn

# ==================== Swagger 文档 ====================
ENABLE_SWAGGER=false

# ============================================================
#  翻译服务（当前仅支持百度翻译，无 LLM / OpenAI 集成）
# ============================================================

# 翻译提供商: mock（仅返回占位文本）| baidu（百度翻译 API）| baidu_cloud（百度云翻译）
TRANSLATION_PROVIDER=mock

# ---- 百度翻译 API（TRANSLATION_PROVIDER=baidu 时需要） ----
# 申请地址: https://fanyi-api.baidu.com/
BAIDU_TRANSLATE_APP_ID=
BAIDU_TRANSLATE_SECRET=

# ---- 百度云翻译（TRANSLATION_PROVIDER=baidu_cloud 时需要） ----
# 申请地址: https://console.bce.baidu.com/
BAIDU_TRANSLATE_API_KEY=
BAIDU_TRANSLATE_SECRET_KEY=

# ---- 翻译缓存与限流 ----
TRANSLATION_CACHE_TTL_SECONDS=86400
TRANSLATION_CACHE_MAX_ENTRIES=500
TRANSLATION_MAX_REQUESTS_PER_MINUTE=120

# ============================================================
#  TTS 语音合成 & LLM — 当前版本尚未集成
# ============================================================
# 如需接入，需在代码中新增以下能力：
#   1. 百度 TTS：调用 https://ai.baidu.com/tech/speech/tts
#      → 配置 BAIDU_TTS_APP_ID / BAIDU_TTS_API_KEY / BAIDU_TTS_SECRET_KEY
#   2. LLM 翻译（OpenAI 兼容）：调用任意 OpenAI-compatible API
#      → 配置 LLM_API_URL / LLM_API_KEY / LLM_MODEL
# 当前项目仅支持百度翻译 API 作为翻译后端，无 LLM 和 TTS 实现。
