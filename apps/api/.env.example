NODE_ENV=development
PORT=4100
WEB_ORIGIN=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3000
DATABASE_URL=postgresql://glimpse:glimpse_dev_password@localhost:5432/glimpse_chat?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_with_local_access_secret
JWT_REFRESH_SECRET=replace_with_local_refresh_secret
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=glimpse-chat
S3_ACCESS_KEY=glimpse
S3_SECRET_KEY=glimpse_dev_password
CHAT_STORAGE=memory
DATABASE_CONNECT_ON_START=false
TRANSLATION_PROVIDER=mock
BAIDU_TRANSLATE_APP_ID=replace_with_local_baidu_app_id
BAIDU_TRANSLATE_API_KEY=replace_with_local_baidu_api_key
BAIDU_TRANSLATE_SECRET_KEY=replace_with_local_baidu_secret_key

# Email verification SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=replace_with_smtp_authorization_code
SMTP_FROM=noreply@example.com

